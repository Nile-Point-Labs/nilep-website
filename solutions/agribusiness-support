    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Header Scroll behavior (adds scrolling class to header elements)
            const header = document.getElementById('globalHeader');
            const handleScroll = () => {
                if (window.scrollY > 80) {
                    header.classList.add('scrolled');
                } else {
                    header.classList.remove('scrolled');
                }
            };
            window.addEventListener('scroll', handleScroll);
            handleScroll();

            // Mobile Navigation Overlay Toggle
            const menuToggle = document.getElementById('menuToggle');
            const closeMenu = document.getElementById('closeMenu');
            const mobileOverlay = document.getElementById('mobileOverlay');
            const mobileLinks = document.querySelectorAll('.mobile-nav-link');

            const openMobileNav = () => {
                mobileOverlay.classList.add('open');
                document.body.classList.add('overflow-hidden');
            };

            const closeMobileNav = () => {
                mobileOverlay.classList.remove('open');
                document.body.classList.remove('overflow-hidden');
            };

            menuToggle.addEventListener('click', openMobileNav);
            closeMenu.addEventListener('click', closeMobileNav);
            mobileLinks.forEach(link => {
                link.addEventListener('click', closeMobileNav);
            });

            // Set active page menu link underline logic
            const currentPath = window.location.pathname;
            const desktopLinks = document.querySelectorAll('.nav-link');
            const mobileLinksElem = document.querySelectorAll('.mobile-nav-link');

            const determineActive = (elem) => {
                const linkPath = elem.getAttribute('data-path');
                if (linkPath === currentPath) {
                    elem.classList.add('active');
                } else if (linkPath !== '/' && currentPath.startsWith(linkPath)) {
                    elem.classList.add('active');
                }
            };

            desktopLinks.forEach(determineActive);
            mobileLinksElem.forEach(determineActive);

            // Force fallback selection highlighting because this page relates to /solutions/
            desktopLinks.forEach(el => {
                if (el.getAttribute('data-path') === '/solutions/') {
                    el.classList.add('active');
                } else if (el.getAttribute('data-path') === '/') {
                    el.classList.remove('active');
                }
            });

            mobileLinksElem.forEach(el => {
                if (el.getAttribute('data-path') === '/solutions/') {
                    el.style.color = 'var(--color-green)';
                    el.style.fontWeight = '600';
                }
            });
        });
    </script>
