                            <!-- Field 3: Phone (Optional) -->
                            <div class="form-group mb-6">
                                <label for="form-phone" class="block text-obsidian text-[14px] font-semibold mb-1.5">Phone Number</label>
                                <input type="tel" id="form-phone" name="phone" placeholder="+234 000 000 0000"
                                       class="w-full border border-custom-gray rounded-[6px] px-4 py-3.5 text-base text-obsidian bg-white-pure outline-none transition-all duration-200 focus:border-green-brand focus:ring-[3px] focus:ring-[#1A6B3C]/10">
                            </div>

                            <!-- Field 4: Organisation (Optional) -->
                            <div class="form-group mb-6">
                                <label for="form-organisation" class="block text-obsidian text-[14px] font-semibold mb-1.5">Organisation or Company</label>
                                <input type="text" id="form-organisation" name="organisation" placeholder="Your company or organisation"
                                       class="w-full border border-custom-gray rounded-[6px] px-4 py-3.5 text-base text-obsidian bg-white-pure outline-none transition-all duration-200 focus:border-green-brand focus:ring-[3px] focus:ring-[#1A6B3C]/10">
                            </div>

