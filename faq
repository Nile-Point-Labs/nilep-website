    <!-- INTERACTIVE SCRIPTS -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Reusable sticky global header scroll logic
            const header = document.getElementById('globalHeader');
            const handleScroll = () => {
                if (window.scrollY > 80) {
                    header.classList.add('scrolled');
                } else {
                    header.classList.remove('scrolled');
                }
            };
            window.addEventListener('scroll', handleScroll);
            handleScroll(); // Trigger instantly on layout paint

            // Full-screen overlay setup for tablets and mobile devices
            const menuToggle = document.getElementById('menuToggle');
            const closeMenu = document.getElementById('closeMenu');
            const mobileOverlay = document.getElementById('mobileOverlay');
            const mobileLinks = document.querySelectorAll('.mobile-nav-link');

            const openOverlay = () => {
                mobileOverlay.classList.add('open');
                document.body.classList.add('overflow-hidden');
            };

            const closeOverlay = () => {
                mobileOverlay.classList.remove('open');
                document.body.classList.remove('overflow-hidden');
            };

            menuToggle.addEventListener('click', openOverlay);
            closeMenu.addEventListener('click', closeOverlay);
            mobileLinks.forEach(link => {
                link.addEventListener('click', closeOverlay);
            });

            // FAQ Accordion Logics
            const faqTriggers = document.querySelectorAll('.faq-trigger');

            faqTriggers.forEach(trigger => {
                trigger.addEventListener('click', () => {
                    const currentItem = trigger.closest('.faq-item');
                    const currentContainer = currentItem.querySelector('.faq-answer-container');
                    const isActive = currentItem.classList.contains('active');

                    // Close all other items inside the entire FAQ page
                    document.querySelectorAll('.faq-item').forEach(item => {
                        item.classList.remove('active');
                        item.querySelector('.faq-answer-container').style.maxHeight = '0';
                    });

                    // Toggle status for the clicked item
                    if (!isActive) {
                        currentItem.classList.add('active');
                        // Calculate specific heights dynamically to allow accurate animation sizing
                        currentContainer.style.maxHeight = currentContainer.scrollHeight + 'px';
                    }
                });
            });
        });
    </script>
</body>
</html>
